---
import Layout from '../layouts/Layout.astro';
import { siteConfig as fallbackConfig } from '../data/site';
import { getHomepageData } from '../lib/sanity';

const { profile, banners, featuredLinks, socials, seo } = await getHomepageData(fallbackConfig);
---

<Layout title={seo.title} description={seo.description}>
	<main class="page">
		<div class="ambient ambient-one"></div>
		<div class="ambient ambient-two"></div>

		<section class="card profile">
			<div class="profile-top">
				<img class="avatar" src={profile.avatar} alt={profile.name} loading="lazy" />
				<div>
					<p class="eyebrow">{profile.location}</p>
					<h1>{profile.name}</h1>
					<p class="tagline">{profile.tagline}</p>
				</div>
			</div>
			<p class="description">{profile.description}</p>
		</section>

		<section class="stack" aria-label="Banners destacados">
			{
				banners.map((banner) => (
					<article class="card banner">
						<img src={banner.image} alt={banner.title} loading="lazy" />
						<div>
							<h2>{banner.title}</h2>
							<p>{banner.subtitle}</p>
							<a href={banner.buttonUrl} target="_blank" rel="noreferrer">{banner.buttonLabel}</a>
						</div>
					</article>
				))
			}
		</section>

		<section class="stack" aria-label="Enlaces principales">
			{
				featuredLinks.map((link) => (
					<a class:list={{ card: true, link: true, featured: Boolean(link.featured) }} href={link.url} target="_blank" rel="noreferrer">
						<span class="icon">{link.emoji}</span>
						<span>
							<strong>{link.label}</strong>
							<small>{link.note}</small>
						</span>
						<span aria-hidden="true">↗</span>
					</a>
				))
			}
		</section>

		<footer class="card footer">
			<div class="socials">
				{
					socials.map((social) => (
						<a href={social.url} target="_blank" rel="noreferrer" aria-label={social.label} title={social.label}>
							{social.short}
						</a>
					))
				}
			</div>
			<p>Hecho con amor para Las Cositas de Sita.</p>
		</footer>
	</main>
</Layout>

<style>
	:root {
		--sita-blue: #0066ff;
		--sita-orange: #ff6b35;
		--sita-slate: #6b7280;
		--sita-ink: #0a1128;
		--sita-cream: #fafaf8;
		--surface: #ffffffd9;
	}

	.page {
		position: relative;
		max-width: 760px;
		margin: 0 auto;
		padding: 1.2rem 1rem 2rem;
	}

	.ambient {
		position: fixed;
		z-index: -1;
		filter: blur(55px);
		opacity: 0.45;
		pointer-events: none;
	}

	.ambient-one {
		top: -60px;
		left: -40px;
		width: 260px;
		height: 260px;
		background: radial-gradient(circle, var(--sita-orange), transparent 65%);
	}

	.ambient-two {
		bottom: -90px;
		right: -20px;
		width: 290px;
		height: 290px;
		background: radial-gradient(circle, var(--sita-blue), transparent 68%);
	}

	.card {
		background: var(--surface);
		border: 1px solid #ffffff;
		border-radius: 20px;
		backdrop-filter: blur(8px);
		box-shadow: 0 20px 45px #0a112812;
	}

	.profile {
		padding: 1.15rem;
		animation: rise 520ms ease-out;
	}

	.profile-top {
		display: flex;
		align-items: center;
		gap: 0.9rem;
	}

	.avatar {
		width: 78px;
		height: 78px;
		object-fit: cover;
		border-radius: 24px;
		border: 3px solid var(--sita-blue);
	}

	.eyebrow {
		margin: 0;
		font-size: 0.77rem;
		letter-spacing: 0.09em;
		text-transform: uppercase;
		color: var(--sita-slate);
	}

	h1 {
		margin: 0.1rem 0 0;
		font-size: 1.52rem;
		line-height: 1.2;
	}

	.tagline {
		margin: 0.2rem 0 0;
		color: var(--sita-orange);
		font-weight: 700;
	}

	.description {
		margin: 0.9rem 0 0;
		line-height: 1.55;
		color: #2a355f;
	}

	.stack {
		display: grid;
		gap: 0.78rem;
		margin-top: 0.82rem;
	}

	.banner {
		display: grid;
		grid-template-columns: minmax(95px, 130px) 1fr;
		gap: 0.86rem;
		padding: 0.72rem;
		animation: rise 620ms ease-out;
	}

	.banner img {
		width: 100%;
		height: 100%;
		max-height: 112px;
		object-fit: cover;
		border-radius: 14px;
	}

	.banner h2 {
		margin: 0;
		font-size: 1rem;
	}

	.banner p {
		margin: 0.3rem 0 0.72rem;
		font-size: 0.9rem;
		color: var(--sita-slate);
	}

	.banner a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.52rem 0.86rem;
		border-radius: 10px;
		text-decoration: none;
		font-weight: 700;
		background: var(--sita-ink);
		color: var(--sita-cream);
		transition: transform 160ms ease, background 160ms ease;
	}

	.banner a:hover {
		transform: translateY(-2px);
		background: var(--sita-blue);
	}

	.link {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 0.8rem;
		padding: 0.95rem 1rem;
		color: inherit;
		text-decoration: none;
		animation: rise 720ms ease-out;
		transition: transform 140ms ease, box-shadow 140ms ease;
	}

	.link:hover {
		transform: translateY(-2px);
		box-shadow: 0 15px 24px #0a112826;
	}

	.link.featured {
		border: 2px solid var(--sita-orange);
	}

	.link strong {
		display: block;
		font-size: 1rem;
	}

	.link small {
		color: var(--sita-slate);
	}

	.icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.35rem;
		height: 2.35rem;
		font-size: 1.1rem;
		border-radius: 0.9rem;
		background: linear-gradient(135deg, #ff6b3533, #0066ff29);
	}

	.footer {
		margin-top: 0.85rem;
		padding: 1rem;
		text-align: center;
		animation: rise 800ms ease-out;
	}

	.socials {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.56rem;
	}

	.socials a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 2.2rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 800;
		color: var(--sita-ink);
		background: #ffffff;
		border: 1px solid #d7dbe4;
	}

	.footer p {
		margin: 0.75rem 0 0;
		font-size: 0.86rem;
		color: var(--sita-slate);
	}

	@keyframes rise {
		from {
			opacity: 0;
			transform: translateY(14px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 640px) {
		.page {
			padding: 0.95rem 0.72rem 1.6rem;
		}

		h1 {
			font-size: 1.32rem;
		}

		.banner {
			grid-template-columns: 1fr;
		}

		.banner img {
			max-height: 160px;
		}
	}
</style>
